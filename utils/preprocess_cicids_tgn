import numpy as np
import pandas as pd
from sklearn.preprocessing import LabelEncoder, StandardScaler
import os

def preprocess_cicids2017(input_csv_path, output_dir='./data/', dataset_name='cicids'):
    """
    Preprocess CICIDS2017 dataset for TGN
    
    Args:
        input_csv_path: Path to the raw CICIDS2017 CSV file
        output_dir: Directory to save processed files
        dataset_name: Name to use for the output files
    """
    
    # Create output directory if it doesn't exist
    os.makedirs(output_dir, exist_ok=True)
    
    # Read the CSV file
    print("Loading CICIDS2017 data...")
    df = pd.read_csv(input_csv_path)
    
    # CICIDS2017 specific preprocessing
    # Handle infinite values and NaN
    df = df.replace([np.inf, -np.inf], np.nan)
    df = df.dropna()
    
    # Identify features (all columns except label/timestamp related ones)
    # Adjust these column names based on your actual CICIDS2017 column names
    label_column = 'Label'  # Change this to your actual label column name
    timestamp_column = 'Timestamp'  # Change this to your actual timestamp column
    
    # Get feature columns (all except label and timestamp)
    feature_columns = [col for col in df.columns if col not in [label_column, timestamp_column]]
    
    # Normalize features
    scaler = StandardScaler()
    features_scaled = scaler.fit_transform(df[feature_columns])
    
    # Convert timestamp to numeric (if it's not already)
    # You might need to customize this based on your timestamp format
    if timestamp_column in df.columns:
        # Assuming timestamp is already numeric, if not, convert it
        if df[timestamp_column].dtype == 'object':
            # Try to parse datetime
            timestamps = pd.to_datetime(df[timestamp_column]).astype(int) // 10**9  # Convert to Unix timestamp
        else:
            timestamps = df[timestamp_column].values
    else:
        # If no timestamp column, create sequential timestamps
        timestamps = np.arange(len(df))
    
    # Encode labels as binary (assuming binary classification)
    # Adjust this based on your label format
    le = LabelEncoder()
    labels = le.fit_transform(df[label_column])
    
    # For TGN, we need to create source and destination nodes
    # In network traffic, we can use IP addresses or create synthetic node pairs
    # Here's one approach: treat each flow as an interaction between source IP and destination IP
    
    # Check if we have IP columns, otherwise create synthetic node IDs
    if 'Source IP' in df.columns and 'Destination IP' in df.columns:
        # Encode IPs as integers
        source_ips = LabelEncoder().fit_transform(df['Source IP'])
        dest_ips = LabelEncoder().fit_transform(df['Destination IP'])
    else:
        # Create synthetic node pairs (each flow is between a unique source-destination pair)
        # This is a simplification - you might want a different approach
        n_flows = len(df)
        source_ips = np.arange(n_flows)  # Each flow has a unique source
        dest_ips = (np.arange(n_flows) + 1) % n_flows  # Each flow has a unique destination
    
    # Create edge indices (just sequential)
    edge_idxs = np.arange(len(df))
    
    # Prepare the graph dataframe
    graph_df = pd.DataFrame({
        'u': source_ips,
        'i': dest_ips,
        'ts': timestamps,
        'idx': edge_idxs,
        'label': labels
    })
    
    # Sort by timestamp
    graph_df = graph_df.sort_values('ts').reset_index(drop=True)
    
    # Save the graph dataframe
    output_csv_path = os.path.join(output_dir, f'ml_{dataset_name}.csv')
    graph_df.to_csv(output_csv_path, index=False)
    print(f"Saved graph data to {output_csv_path}")
    
    # Create edge features (use the normalized flow features)
    # Make sure to reorder features to match the sorted graph_df
    feature_order = graph_df['idx'].values
    edge_features = features_scaled[feature_order]
    
    # Save edge features
    edge_features_path = os.path.join(output_dir, f'ml_{dataset_name}.npy')
    np.save(edge_features_path, edge_features)
    print(f"Saved edge features to {edge_features_path}")
    
    # Create node features
    # Get unique nodes (both sources and destinations)
    unique_nodes = sorted(set(graph_df['u'].unique()) | set(graph_df['i'].unique()))
    n_unique_nodes = len(unique_nodes)
    n_features = edge_features.shape[1]  # Use same dimension as edge features
    
    # Create node features (you might want to customize this)
    # Here we're creating random features as a placeholder
    # In practice, you might want to aggregate flow features per node
    np.random.seed(42)
    node_features = np.random.randn(n_unique_nodes, n_features)
    
    # Save node features
    node_features_path = os.path.join(output_dir, f'ml_{dataset_name}_node.npy')
    np.save(node_features_path, node_features)
    print(f"Saved node features to {node_features_path}")
    
    # Print statistics
    print(f"\nDataset Statistics:")
    print(f"Total interactions: {len(graph_df)}")
    print(f"Unique nodes: {n_unique_nodes}")
    print(f"Feature dimension: {n_features}")
    print(f"Label distribution: {np.bincount(labels)}")
    
    return graph_df, edge_features, node_features

# Example usage
if __name__ == "__main__":
    # Replace with your actual CICIDS2017 file path
    input_file = "path/to/your/cicids2017.csv"
    graph_df, edge_features, node_features = preprocess_cicids2017(
        input_file, 
        output_dir='./data/', 
        dataset_name='cicids'
    )
