import pandas as pd
import numpy as np
import glob
from pathlib import Path

INPUT_FOLDER = "/content/drive/MyDrive/flows"
OUTPUT_FOLDER = "data"
DATASET_NAME = "cicids"

def load_cicids(input_folder):
    """Load all CSV files from the input folder"""
    files = glob.glob(f"{input_folder}/*.csv")
    dfs = []
    for f in files:
        print("Reading:", f)
        df = pd.read_csv(f, encoding="latin1", low_memory=False)
        dfs.append(df)
    return pd.concat(dfs, ignore_index=True)

def preprocess_cicids():
    """EXACT replica of preprocess_data.py workflow"""
    print("="*60)
    print("CICIDS Preprocessor for TGN")
    print("="*60)
    
    # STEP 1: Load and prepare data (like reading the raw CSV in preprocess_data.py)
    print("\n1. Loading and preparing data...")
    df = load_cicids(INPUT_FOLDER)
    df.columns = df.columns.str.strip()
    
    # Convert timestamps
    df["ts"] = pd.to_datetime(df["Timestamp"], errors="coerce").astype(np.int64) // 10**9
    df = df.dropna(subset=["ts"])
    df = df.sort_values("ts").reset_index(drop=True)
    
    # Create initial node mappings (0-based, continuous)
    all_ips = pd.concat([df["Source IP"], df["Destination IP"]]).unique()
    node_map = {ip: idx for idx, ip in enumerate(all_ips)}
    
    df["u"] = df["Source IP"].map(node_map)
    df["i"] = df["Destination IP"].map(node_map)
    df["label"] = (df["Label"] != "BENIGN").astype(int)
    df["idx"] = np.arange(len(df))
    
    # Extract features
    exclude_cols = ["Source IP", "Destination IP", "Timestamp", "Label", "u", "i", "ts", "idx", "label"]
    feature_cols = [c for c in df.columns if c not in exclude_cols]
    edge_features = df[feature_cols].apply(pd.to_numeric, errors='coerce').fillna(0).values.astype(np.float32)
    
    # Normalize
    if edge_features.shape[1] > 0:
        min_vals = edge_features.min(axis=0)
        max_vals = edge_features.max(axis=0)
        denom = max_vals - min_vals
        denom[denom == 0] = 1
        edge_features = (edge_features - min_vals) / denom
    
    # STEP 2: Save raw data (like the input CSV in preprocess_data.py)
    print("\n2. Saving raw data...")
    Path("data/").mkdir(parents=True, exist_ok=True)
    raw_df = df[["u", "i", "ts", "label", "idx"]].copy()
    raw_df.to_csv(f"data/{DATASET_NAME}.csv", index=False)
    print(f"   Saved raw data with {len(raw_df)} edges")
    print(f"   Node IDs: {raw_df['u'].min()} to {raw_df['u'].max()}")
    
    # STEP 3: Verify continuous IDs (like the assert in preprocess_data.py)
    print("\n3. Verifying continuous node IDs...")
    u_continuous = (raw_df.u.max() - raw_df.u.min() + 1 == len(raw_df.u.unique()))
    i_continuous = (raw_df.i.max() - raw_df.i.min() + 1 == len(raw_df.i.unique()))
    print(f"   Source nodes continuous: {u_continuous}")
    print(f"   Destination nodes continuous: {i_continuous}")
    
    if not u_continuous or not i_continuous:
        print("   â ï¸  Warning: Node IDs are not continuous. Renumbering...")
        # Renumber to make continuous
        all_nodes = pd.concat([raw_df["u"], raw_df["i"]]).unique()
        new_node_map = {old_id: new_id for new_id, old_id in enumerate(sorted(all_nodes))}
        raw_df["u"] = raw_df["u"].map(new_node_map)
        raw_df["i"] = raw_df["i"].map(new_node_map)
        
        # Also need to renumber edge features order
        new_edge_features = np.zeros_like(edge_features)
        for old_idx, new_idx in enumerate(sorted(all_nodes)):
            if old_idx in new_node_map:
                pass  # Features are per edge, not per node, so no change needed
        
        print(f"   New node range: {raw_df['u'].min()} to {raw_df['u'].max()}")
    
    # STEP 4: Reindex (add 1 to all indices, like preprocess_data.py)
    print("\n4. Reindexing (adding 1 to all indices)...")
    reindexed_df = raw_df.copy()
    reindexed_df["u"] = reindexed_df["u"] + 1
    reindexed_df["i"] = reindexed_df["i"] + 1
    reindexed_df["idx"] = reindexed_df["idx"] + 1
    
    print(f"   New node range: {reindexed_df['u'].min()} to {reindexed_df['u'].max()}")
    print(f"   New edge index range: {reindexed_df['idx'].min()} to {reindexed_df['idx'].max()}")
    
    # STEP 5: Add empty first row to edge features (like preprocess_data.py)
    print("\n5. Adding dummy first row to edge features...")
    empty = np.zeros((1, edge_features.shape[1]))
    edge_features_with_dummy = np.vstack([empty, edge_features])
    print(f"   Edge features shape: {edge_features_with_dummy.shape}")
    
    # STEP 6: Create node features (zeros with size = max_id + 1, like preprocess_data.py)
    print("\n6. Creating node features...")
    max_id = max(reindexed_df["u"].max(), reindexed_df["i"].max())
    node_features = np.zeros((max_id + 1, 172)).astype(np.float32)
    print(f"   Node features shape: {node_features.shape}")
    print(f"   This includes node 0 (dummy) through node {max_id}")
    
    # STEP 7: Save final files
    print("\n7. Saving final files...")
    reindexed_df.to_csv(f"data/ml_{DATASET_NAME}.csv", index=False)
    np.save(f"data/ml_{DATASET_NAME}.npy", edge_features_with_dummy)
    np.save(f"data/ml_{DATASET_NAME}_node.npy", node_features)
    
    print("\n" + "="*60)
    print("PREPROCESSING COMPLETE")
    print("="*60)
    print(f"Dataset: {DATASET_NAME}")
    print(f"Edges: {len(reindexed_df)}")
    print(f"Node features: {node_features.shape}")
    print(f"  - Index 0: DUMMY NODE")
    print(f"  - Indices 1-{max_id}: Real nodes")
    print(f"Edge features: {edge_features_with_dummy.shape}")
    print(f"  - Row 0: DUMMY (all zeros)")
    print(f"  - Rows 1-{len(edge_features)}: Real edge features")
    print("="*60)
    
    # Final verification
    print("\n8. Final verification:")
    print(f"   Node ID range in CSV: {reindexed_df['u'].min()} to {reindexed_df['u'].max()}")
    print(f"   Node features cover: 0 to {node_features.shape[0]-1}")
    print(f"   Edge features cover: 0 to {edge_features_with_dummy.shape[0]-1}")
    
    if reindexed_df['u'].max() < node_features.shape[0]:
        print("   â Node features array is large enough")
    else:
        print(f"   â ERROR: Node features too small! Need at least {reindexed_df['u'].max()+1}")
    
    return reindexed_df, edge_features_with_dummy, node_features

if __name__ == "__main__":
    try:
        df, edge_features, node_features = preprocess_cicids()
        print("\nâ Preprocessing successful!")
        print("\nNow run training with:")
        print(f"python train_self_supervised.py --data {DATASET_NAME} --bs 200 --n_epoch 50 --use_memory --memory_dim 172 --prefix tgn --gpu 0")
    except Exception as e:
        print(f"\nâ ERROR: {e}")
        import traceback
        traceback.print_exc()
