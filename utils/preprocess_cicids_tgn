import pandas as pd
import numpy as np
import glob
from pathlib import Path

INPUT_FOLDER = "/content/drive/MyDrive/flows"
OUTPUT_FOLDER = "data"
DATASET_NAME = "cicids"

def load_cicids(input_folder):
    """Load all CSV files from the input folder"""
    files = glob.glob(f"{input_folder}/*.csv")
    dfs = []
    for f in files:
        print("Reading:", f)
        df = pd.read_csv(f, encoding="latin1", low_memory=False)
        dfs.append(df)
    return pd.concat(dfs, ignore_index=True)

def preprocess_cicids():
    """Main preprocessing function matching the data_processing.py expectations"""
    print("="*60)
    print("CICIDS Preprocessor for TGN")
    print("="*60)
    
    # Load data
    print("\n1. Loading data...")
    df = load_cicids(INPUT_FOLDER)
    print(f"   Loaded {len(df)} rows")
    
    # Clean column names
    df.columns = df.columns.str.strip()
    
    # Convert timestamps to UNIX time
    print("\n2. Processing timestamps...")
    df["ts"] = pd.to_datetime(df["Timestamp"], errors="coerce").astype(np.int64) // 10**9
    df = df.dropna(subset=["ts"])
    print(f"   Valid timestamps: {len(df)} rows")
    
    # Sort by timestamp
    df = df.sort_values("ts").reset_index(drop=True)
    
    # Create node mappings (sequential from 0, but will be +1 in data_processing)
    print("\n3. Mapping IPs to node IDs...")
    all_ips = pd.concat([df["Source IP"], df["Destination IP"]]).unique()
    node_map = {ip: idx for idx, ip in enumerate(all_ips)}  # Start from 0
    print(f"   Total unique nodes: {len(node_map)}")
    
    df["u"] = df["Source IP"].map(node_map)
    df["i"] = df["Destination IP"].map(node_map)
    
    # Create labels (1 for attack, 0 for benign)
    df["label"] = (df["Label"] != "BENIGN").astype(int)
    
    # Create edge indices
    df["idx"] = np.arange(len(df))
    
    # Extract edge features
    print("\n4. Extracting edge features...")
    exclude_cols = ["Source IP", "Destination IP", "Timestamp", "Label", 
                    "u", "i", "ts", "idx", "label"]
    feature_cols = [c for c in df.columns if c not in exclude_cols]
    print(f"   Found {len(feature_cols)} feature columns")
    
    # Convert to numeric and handle missing
    edge_features = df[feature_cols].apply(pd.to_numeric, errors='coerce').fillna(0).values
    edge_features = edge_features.astype(np.float32)
    
    # Normalize features to [0,1] range
    if edge_features.shape[1] > 0:
        print("   Normalizing features...")
        min_vals = edge_features.min(axis=0)
        max_vals = edge_features.max(axis=0)
        denom = max_vals - min_vals
        denom[denom == 0] = 1
        edge_features = (edge_features - min_vals) / denom
    
    print(f"   Edge features shape: {edge_features.shape}")
    
    # Create node features (random, matching the expected dimension)
    print("\n5. Creating node features...")
    num_nodes = len(node_map)
    # Node features dimension should match what TGN expects (172)
    node_features = np.random.randn(num_nodes, 172).astype(np.float32)
    print(f"   Node features shape: {node_features.shape}")
    
    # Final dataframe with required columns
    final_df = df[["u", "i", "ts", "label", "idx"]].copy()
    
    # Verify format
    print("\n6. Verifying output format...")
    print(f"   Node IDs: min={final_df['u'].min()}, max={final_df['u'].max()}")
    print(f"   Edge indices: min={final_df['idx'].min()}, max={final_df['idx'].max()}")
    print(f"   Labels distribution: {final_df['label'].value_counts().to_dict()}")
    print(f"   Timestamp range: {final_df['ts'].min()} to {final_df['ts'].max()}")
    
    # Quick check for any timestamp ordering issues
    print("\n7. Checking temporal ordering...")
    df_sorted = final_df.sort_values(['ts', 'idx'])
    is_monotonic = (df_sorted['ts'].diff().iloc[1:] >= 0).all()
    if is_monotonic:
        print("   ✅ Timestamps are monotonically increasing")
    else:
        print("   ⚠️  Warning: Some timestamps are out of order")
        # Force final sort
        final_df = final_df.sort_values(['ts', 'idx']).reset_index(drop=True)
        final_df['idx'] = np.arange(len(final_df))
        print("   ✅ Re-sorted by timestamp")
    
    return final_df, edge_features, node_features

def save_outputs(df, edge_features, node_features):
    """Save in the format expected by data_processing.py"""
    print("\n8. Saving files...")
    
    Path(OUTPUT_FOLDER).mkdir(parents=True, exist_ok=True)
    
    # Save main data file (this is what data_processing.py reads)
    df.to_csv(f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}.csv", index=False)
    print(f"   ✅ Saved: ml_{DATASET_NAME}.csv")
    print(f"      Shape: {df.shape}")
    print(f"      Columns: {list(df.columns)}")
    
    # Save edge features (ml_{dataset}.npy)
    np.save(f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}.npy", edge_features)
    print(f"   ✅ Saved: ml_{DATASET_NAME}.npy")
    print(f"      Shape: {edge_features.shape}")
    
    # Save node features (ml_{dataset}_node.npy)
    np.save(f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}_node.npy", node_features)
    print(f"   ✅ Saved: ml_{DATASET_NAME}_node.npy")
    print(f"      Shape: {node_features.shape}")
    
    # Print summary
    print("\n" + "="*60)
    print("PREPROCESSING COMPLETE")
    print("="*60)
    print(f"Dataset: {DATASET_NAME}")
    print(f"Number of edges: {len(df)}")
    print(f"Number of nodes: {len(node_features)}")
    print(f"Edge features dimension: {edge_features.shape[1]}")
    print(f"Node features dimension: {node_features.shape[1]}")
    print("\nFiles created:")
    print(f"  - data/ml_{DATASET_NAME}.csv")
    print(f"  - data/ml_{DATASET_NAME}.npy")
    print(f"  - data/ml_{DATASET_NAME}_node.npy")
    print("="*60)
    
    # Verify files can be read by data_processing.py
    print("\n9. Verifying files can be loaded...")
    try:
        test_df = pd.read_csv(f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}.csv")
        test_edge = np.load(f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}.npy")
        test_node = np.load(f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}_node.npy")
        print("   ✅ All files loaded successfully")
        print(f"   CSV columns: {list(test_df.columns)}")
        print(f"   Edge features: {test_edge.shape}")
        print(f"   Node features: {test_node.shape}")
    except Exception as e:
        print(f"   ❌ Error loading files: {e}")

if __name__ == "__main__":
    try:
        # Run preprocessing
        df, edge_features, node_features = preprocess_cicids()
        save_outputs(df, edge_features, node_features)
        
        print("\n" + "="*60)
        print("NEXT STEPS:")
        print("="*60)
        print("Run training with:")
        print(f"python train_self_supervised.py --data {DATASET_NAME} --bs 200 --n_epoch 50 --use_memory --memory_dim 172 --prefix tgn --gpu 0")
        print("="*60)
        
    except Exception as e:
        print(f"\n❌ ERROR: {e}")
        import traceback
        traceback.print_exc()
