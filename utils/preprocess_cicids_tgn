import pandas as pd
import numpy as np
import glob
import os
from pathlib import Path

INPUT_FOLDER = "/content/drive/MyDrive/flows"  # your CICIDS CSV folder
OUTPUT_FOLDER = "data"
DATASET_NAME = "cicids"
NODE_FEATURE_DIM = 172

Path(OUTPUT_FOLDER).mkdir(parents=True, exist_ok=True)

print("Loading CICIDS flow files...")
files = glob.glob(f"{INPUT_FOLDER}/*.csv")
dfs = []

for f in files:
    print("Reading:", f)
    df = pd.read_csv(f, encoding="latin1", low_memory=False)
    dfs.append(df)

df = pd.concat(dfs, ignore_index=True)

# Strip whitespace from columns
df.columns = df.columns.str.strip()

# Convert timestamps
df["ts"] = pd.to_datetime(df["Timestamp"], errors="coerce").astype("int64") // 10**9

# Map IPs to contiguous node IDs
node_map = {}
node_id = 0
def map_node(ip):
    global node_id
    if ip not in node_map:
        node_map[ip] = node_id
        node_id += 1
    return node_map[ip]

df["u"] = df["Source IP"].apply(map_node)
df["i"] = df["Destination IP"].apply(map_node)

# Generate index
df["idx"] = np.arange(len(df))

# Binary label
df["label"] = (df["Label"] != "BENIGN").astype(int)

# Sort by timestamp
df = df.sort_values("ts")

# Edge feature columns (exclude identifiers)
exclude_cols = ["Source IP","Destination IP","Timestamp","Label","u","i","ts","idx","label"]
feature_cols = [c for c in df.columns if c not in exclude_cols]

# Convert edge features to float32 and fill NaNs
edge_features = df[feature_cols].apply(pd.to_numeric, errors='coerce').fillna(0).values.astype(np.float32)

# Normalize edge features (mean 0, std 1)
mean_feat = edge_features.mean(axis=0, keepdims=True)
std_feat = edge_features.std(axis=0, keepdims=True) + 1e-6
edge_features = (edge_features - mean_feat) / std_feat

# Node features: random in [0,1]
num_nodes = max(df["u"].max(), df["i"].max()) + 1
node_features = np.random.rand(num_nodes, NODE_FEATURE_DIM).astype(np.float32)

# Save files
graph_df = df[["u", "i", "ts", "idx", "label"]]
graph_df.to_csv(f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}.csv", index=False)
np.save(f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}.npy", edge_features)
np.save(f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}_node.npy", node_features)

print("Done.")
print("Edges:", len(graph_df))
print("Nodes:", num_nodes)
