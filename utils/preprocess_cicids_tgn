import pandas as pd
import numpy as np
import glob
from pathlib import Path

INPUT_FOLDER = "/content/drive/MyDrive/flows"
OUTPUT_FOLDER = "data"
DATASET_NAME = "cicids"

def load_cicids(input_folder):
    """Load all CSV files from the input folder"""
    files = glob.glob(f"{input_folder}/*.csv")
    dfs = []
    for f in files:
        print("Reading:", f)
        df = pd.read_csv(f, encoding="latin1", low_memory=False)
        dfs.append(df)
    return pd.concat(dfs, ignore_index=True)

def preprocess_cicids():
    """Main preprocessing function"""
    print("="*60)
    print("CICIDS Preprocessor for TGN")
    print("="*60)
    
    # Load data
    print("\n1. Loading data...")
    df = load_cicids(INPUT_FOLDER)
    print(f"   Loaded {len(df)} rows")
    
    # Clean column names
    df.columns = df.columns.str.strip()
    
    # Convert timestamps
    print("\n2. Processing timestamps...")
    df["ts"] = pd.to_datetime(df["Timestamp"], errors="coerce").astype(np.int64) // 10**9
    df = df.dropna(subset=["ts"])
    print(f"   Valid timestamps: {len(df)} rows")
    
    # Sort by time
    df = df.sort_values("ts").reset_index(drop=True)
    
    # Create node mappings (START FROM 1, NOT 0)
    print("\n3. Mapping IPs to node IDs...")
    all_ips = pd.concat([df["Source IP"], df["Destination IP"]]).unique()
    node_map = {ip: idx + 1 for idx, ip in enumerate(all_ips)}  # Start from 1
    print(f"   Total unique nodes: {len(node_map)}")
    
    df["u"] = df["Source IP"].map(node_map)
    df["i"] = df["Destination IP"].map(node_map)
    
    # Create labels (1 for attack, 0 for benign)
    df["label"] = (df["Label"] != "BENIGN").astype(int)
    
    # Create edge indices (START FROM 1)
    df["idx"] = np.arange(1, len(df) + 1)
    
    # Extract features
    print("\n4. Extracting edge features...")
    exclude_cols = ["Source IP", "Destination IP", "Timestamp", "Label", 
                    "u", "i", "ts", "idx", "label"]
    feature_cols = [c for c in df.columns if c not in exclude_cols]
    
    # Convert to numeric and handle missing
    edge_features = df[feature_cols].apply(pd.to_numeric, errors='coerce').fillna(0).values
    edge_features = edge_features.astype(np.float32)
    
    # Normalize features
    if edge_features.shape[1] > 0:
        min_vals = edge_features.min(axis=0)
        max_vals = edge_features.max(axis=0)
        denom = max_vals - min_vals
        denom[denom == 0] = 1
        edge_features = (edge_features - min_vals) / denom
    print(f"   Edge features shape: {edge_features.shape}")
    
    # Create node features (random, as in original TGN)
    print("\n5. Creating node features...")
    num_nodes = len(node_map)
    node_features = np.random.randn(num_nodes + 1, 172).astype(np.float32)  # +1 for index 0
    node_features[0] = 0  # Zero out the first row (unused node)
    print(f"   Node features shape: {node_features.shape}")
    
    # Final dataframe with correct format
    final_df = df[["u", "i", "ts", "label", "idx"]].copy()
    
    # Verify data format
    print("\n6. Verifying data format...")
    print(f"   Node IDs range: {final_df['u'].min()} to {final_df['u'].max()}")
    print(f"   Edge indices range: {final_df['idx'].min()} to {final_df['idx'].max()}")
    print(f"   Labels distribution: {final_df['label'].value_counts().to_dict()}")
    
    # Check for temporal ordering issues
    print("\n7. Checking temporal ordering...")
    
    # Group by source node and check timestamps
    problematic_nodes = 0
    for node_id in final_df['u'].unique()[:100]:  # Check first 100 nodes
        node_edges = final_df[final_df['u'] == node_id].sort_values('ts')
        if len(node_edges) > 1:
            diffs = node_edges['ts'].diff().iloc[1:]
            if (diffs <= 0).any():
                problematic_nodes += 1
                # Fix by adding small epsilon
                ts_values = node_edges['ts'].values
                for j in range(1, len(ts_values)):
                    if ts_values[j] <= ts_values[j-1]:
                        ts_values[j] = ts_values[j-1] + 1e-6
                final_df.loc[node_edges.index, 'ts'] = ts_values
    
    if problematic_nodes > 0:
        print(f"   ⚠️  Fixed timestamps for {problematic_nodes} nodes")
    else:
        print("   ✅ All checked nodes have proper temporal ordering")
    
    # Final sort
    final_df = final_df.sort_values(['ts', 'idx']).reset_index(drop=True)
    
    return final_df, edge_features, node_features

def save_outputs(df, edge_features, node_features):
    """Save in the exact format expected by TGN"""
    print("\n8. Saving files...")
    
    Path(OUTPUT_FOLDER).mkdir(parents=True, exist_ok=True)
    
    # Save main data file (format: u,i,ts,label,idx)
    df.to_csv(f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}.csv", index=False)
    print(f"   ✅ Saved: ml_{DATASET_NAME}.csv ({len(df)} edges)")
    
    # Save edge features (first row is empty for index 0)
    edge_features_with_dummy = np.vstack([np.zeros(edge_features.shape[1]), edge_features])
    np.save(f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}_edge.npy", edge_features_with_dummy)
    print(f"   ✅ Saved: ml_{DATASET_NAME}_edge.npy {edge_features_with_dummy.shape}")
    
    # Save node features
    np.save(f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}_node.npy", node_features)
    print(f"   ✅ Saved: ml_{DATASET_NAME}_node.npy {node_features.shape}")
    
    # Print summary
    print("\n" + "="*60)
    print("PREPROCESSING COMPLETE - READY FOR TRAINING")
    print("="*60)
    print(f"Dataset: {DATASET_NAME}")
    print(f"Number of edges: {len(df)}")
    print(f"Number of nodes: {node_features.shape[0] - 1}")  # Subtract dummy node 0
    print(f"Edge features dim: {edge_features.shape[1]}")
    print(f"Node features dim: {node_features.shape[1]}")
    print("="*60)
    
    # Verify file format matches expected
    print("\nFile format verification:")
    print("-" * 40)
    print("Expected format (from preprocess_data.txt):")
    print("  - Node IDs start at 1")
    print("  - Edge indices start at 1")
    print("  - Edge features have dummy first row")
    print("  - Node features have dummy first row")
    print("-" * 40)
    print("✓ All format requirements satisfied!")

if __name__ == "__main__":
    try:
        # Run preprocessing
        df, edge_features, node_features = preprocess_cicids()
        save_outputs(df, edge_features, node_features)
        
    except Exception as e:
        print(f"\n❌ ERROR: {e}")
        import traceback
        traceback.print_exc()
