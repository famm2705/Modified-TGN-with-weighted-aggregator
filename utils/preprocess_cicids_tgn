import pandas as pd
import numpy as np
from pathlib import Path
import glob
import argparse

def preprocess_cicids(input_folder, output_prefix="cicids"):
    print("Loading CICIDS flow files...")
    files = glob.glob(f"{input_folder}/*.csv")
    dfs = []
    for f in files:
        print("Reading:", f)
        df = pd.read_csv(f, encoding="latin1", low_memory=False)
        dfs.append(df)

    df = pd.concat(dfs, ignore_index=True)
    print("Cleaning column names...")
    df.columns = df.columns.str.strip()

    print("Converting timestamps to seconds...")
    df["ts"] = pd.to_datetime(df["Timestamp"], errors="coerce").astype("int64") // 10**9

    print("Mapping IPs to contiguous node IDs...")
    node_map = {}
    node_id = 0

    def map_node(ip):
        nonlocal node_id
        if ip not in node_map:
            node_map[ip] = node_id
            node_id += 1
        return node_map[ip]

    df["u"] = df["Source IP"].apply(map_node)
    df["i"] = df["Destination IP"].apply(map_node)

    print("Sorting by timestamp and ensuring strictly increasing timestamps per node...")
    df = df.sort_values(["ts", "u", "i"]).reset_index(drop=True)

    # Add tiny epsilon to guarantee strictly increasing timestamps per node
    epsilon = 1e-6
    df['ts'] += df.groupby('u').cumcount() * epsilon
    df['ts'] += df.groupby('i').cumcount() * epsilon

    print("Generating edge indices and labels...")
    df["idx"] = np.arange(len(df))
    df["label"] = (df["Label"] != "BENIGN").astype(int)

    exclude_cols = ["Source IP", "Destination IP", "Timestamp", "Label", "u", "i", "ts", "idx", "label"]
    feature_cols = [c for c in df.columns if c not in exclude_cols]

    print("Extracting numeric edge features...")
    edge_features = df[feature_cols].apply(pd.to_numeric, errors='coerce').fillna(0).values.astype(np.float32)

    print("Creating node features...")
    num_nodes = max(df["u"].max(), df["i"].max()) + 1
    node_features = np.random.rand(num_nodes, 172).astype(np.float32)

    print("Saving processed files...")
    Path("data/").mkdir(parents=True, exist_ok=True)
    df[["u", "i", "ts", "idx", "label"]].to_csv(f"data/ml_{output_prefix}.csv", index=False)
    np.save(f"data/ml_{output_prefix}.npy", edge_features)
    np.save(f"data/ml_{output_prefix}_node.npy", node_features)

    print("Done. Edges:", len(df), "Nodes:", num_nodes)

if __name__ == "__main__":
    parser = argparse.ArgumentParser('Preprocess CICIDS for TGN')
    parser.add_argument('--input_folder', type=str, required=True,
                        help='Folder containing CICIDS CSV flow files')
    parser.add_argument('--prefix', type=str, default="cicids",
                        help='Prefix for output files')
    args = parser.parse_args()

    preprocess_cicids(args.input_folder, args.prefix)
