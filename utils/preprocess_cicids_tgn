import pandas as pd
import numpy as np
import glob
from pathlib import Path

INPUT_FOLDER = "/content/drive/MyDrive/flows"
OUTPUT_FOLDER = "data"
DATASET_NAME = "cicids"

def load_cicids(input_folder):
    """Load all CSV files from the input folder"""
    files = glob.glob(f"{input_folder}/*.csv")
    dfs = []
    for f in files:
        print("Reading:", f)
        df = pd.read_csv(f, encoding="latin1", low_memory=False)
        dfs.append(df)
    return pd.concat(dfs, ignore_index=True)

def preprocess_cicids():
    """Main preprocessing function"""
    print("="*60)
    print("CICIDS Preprocessor for TGN")
    print("="*60)
    
    # Load data
    print("\n1. Loading data...")
    df = load_cicids(INPUT_FOLDER)
    print(f"   Loaded {len(df)} rows")
    
    # Clean column names
    df.columns = df.columns.str.strip()
    
    # Convert timestamps to UNIX time
    print("\n2. Processing timestamps...")
    df["ts"] = pd.to_datetime(df["Timestamp"], errors="coerce").astype(np.int64) // 10**9
    df = df.dropna(subset=["ts"])
    print(f"   Valid timestamps: {len(df)} rows")
    
    # Sort by timestamp
    df = df.sort_values("ts").reset_index(drop=True)
    
    # Create node mappings (starting from 0 for the CSV)
    print("\n3. Mapping IPs to node IDs...")
    all_ips = pd.concat([df["Source IP"], df["Destination IP"]]).unique()
    node_map = {ip: idx for idx, ip in enumerate(all_ips)}  # Start from 0 for CSV
    print(f"   Total unique nodes: {len(node_map)}")
    
    df["u"] = df["Source IP"].map(node_map)
    df["i"] = df["Destination IP"].map(node_map)
    
    # Create labels (1 for attack, 0 for benign)
    df["label"] = (df["Label"] != "BENIGN").astype(int)
    
    # Create edge indices
    df["idx"] = np.arange(len(df))
    
    # Extract edge features
    print("\n4. Extracting edge features...")
    exclude_cols = ["Source IP", "Destination IP", "Timestamp", "Label", 
                    "u", "i", "ts", "idx", "label"]
    feature_cols = [c for c in df.columns if c not in exclude_cols]
    print(f"   Found {len(feature_cols)} feature columns")
    
    # Convert to numeric and handle missing
    edge_features = df[feature_cols].apply(pd.to_numeric, errors='coerce').fillna(0).values
    edge_features = edge_features.astype(np.float32)
    
    # Normalize features
    if edge_features.shape[1] > 0:
        print("   Normalizing features...")
        min_vals = edge_features.min(axis=0)
        max_vals = edge_features.max(axis=0)
        denom = max_vals - min_vals
        denom[denom == 0] = 1
        edge_features = (edge_features - min_vals) / denom
    
    print(f"   Edge features shape: {edge_features.shape}")
    
    # Create node features (random)
    print("\n5. Creating node features...")
    num_nodes = len(node_map)
    # Add 1 for node 0 (dummy node that TGN expects)
    node_features = np.random.randn(num_nodes + 1, 172).astype(np.float32)
    node_features[0] = 0  # Zero out the dummy node
    print(f"   Node features shape: {node_features.shape}")
    print(f"   Note: First row (index 0) is dummy node")
    
    # Final dataframe
    final_df = df[["u", "i", "ts", "label", "idx"]].copy()
    
    # CRITICAL FIX: Ensure timestamps are strictly increasing PER NODE
    print("\n6. Ensuring temporal ordering per node...")
    
    # Group by source node and fix timestamps
    for node_id in final_df['u'].unique():
        mask = final_df['u'] == node_id
        node_indices = final_df.index[mask].tolist()
        
        if len(node_indices) > 1:
            # Get timestamps for this node
            node_ts = final_df.loc[node_indices, 'ts'].values
            
            # Fix any non-increasing timestamps
            modified = False
            for j in range(1, len(node_ts)):
                if node_ts[j] <= node_ts[j-1]:
                    node_ts[j] = node_ts[j-1] + 1e-6
                    modified = True
            
            if modified:
                final_df.loc[node_indices, 'ts'] = node_ts
    
    # Final sort by timestamp
    final_df = final_df.sort_values('ts').reset_index(drop=True)
    final_df['idx'] = np.arange(len(final_df))
    
    # Verify format
    print("\n7. Verifying output format...")
    print(f"   Node IDs: min={final_df['u'].min()}, max={final_df['u'].max()}")
    print(f"   Edge indices: min={final_df['idx'].min()}, max={final_df['idx'].max()}")
    print(f"   Labels: {final_df['label'].value_counts().to_dict()}")
    
    # Check for any timestamp issues
    ts_diffs = final_df['ts'].diff().iloc[1:]
    if (ts_diffs < 0).any():
        print("   ⚠️  Warning: Still have decreasing timestamps")
    else:
        print("   ✅ All timestamps are increasing")
    
    return final_df, edge_features, node_features

def save_outputs(df, edge_features, node_features):
    """Save files in the format expected by the training script"""
    print("\n8. Saving files...")
    
    Path(OUTPUT_FOLDER).mkdir(parents=True, exist_ok=True)
    
    # Save main data file
    csv_path = f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}.csv"
    df.to_csv(csv_path, index=False)
    print(f"   ✅ Saved: {csv_path}")
    print(f"      Shape: {df.shape}")
    
    # Save edge features
    edge_path = f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}.npy"
    np.save(edge_path, edge_features)
    print(f"   ✅ Saved: {edge_path}")
    print(f"      Shape: {edge_features.shape}")
    
    # Save node features
    node_path = f"{OUTPUT_FOLDER}/ml_{DATASET_NAME}_node.npy"
    np.save(node_path, node_features)
    print(f"   ✅ Saved: {node_path}")
    print(f"      Shape: {node_features.shape}")
    
    print("\n" + "="*60)
    print("PREPROCESSING COMPLETE")
    print("="*60)
    print(f"Dataset: {DATASET_NAME}")
    print(f"Edges: {len(df)}")
    print(f"Nodes in CSV: {df['u'].nunique()} (0 to {df['u'].max()})")
    print(f"Node features: {node_features.shape[0]} total (including dummy node 0)")
    print(f"Edge features dim: {edge_features.shape[1]}")
    print("="*60)

if __name__ == "__main__":
    try:
        df, edge_features, node_features = preprocess_cicids()
        save_outputs(df, edge_features, node_features)
        
        print("\n" + "="*60)
        print("NEXT STEPS:")
        print("="*60)
        print("1. First, verify the data split in data_processing.py:")
        print("   The split uses 70th and 85th percentiles of timestamps")
        print("\n2. Run training with:")
        print(f"   python train_self_supervised.py --data {DATASET_NAME} \\")
        print(f"     --bs 200 --n_epoch 50 --use_memory \\")
        print(f"     --memory_dim 172 --prefix tgn --gpu 0")
        print("="*60)
        
    except Exception as e:
        print(f"\n❌ ERROR: {e}")
        import traceback
        traceback.print_exc()
