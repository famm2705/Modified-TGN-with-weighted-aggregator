import numpy as np
import pandas as pd
import random
import os
from pathlib import Path
from datetime import datetime

class CICIDSTGNPreprocessor:
    """
    Preprocessor for CICIDS2017 dataset to convert it to TGN format
    """
    
    def __init__(self, input_csv_path, output_dir='/content/data', randomize_features=False):
        self.input_csv_path = input_csv_path
        self.output_dir = output_dir
        self.randomize_features = randomize_features
        
        # Create output directory if it doesn't exist
        Path(output_dir).mkdir(parents=True, exist_ok=True)
        
    def preprocess(self):
        """Main preprocessing function"""
        print("="*60)
        print("CICIDS2017 TGN Preprocessor")
        print("="*60)
        
        # Load the data
        print(f"\n1. Loading data from: {self.input_csv_path}")
        df = self._load_data()
        
        # Parse timestamps
        print("\n2. Parsing timestamps...")
        df = self._parse_timestamps(df)
        
        # Sort by time (critical for TGN)
        print("\n3. Sorting chronologically...")
        df = df.sort_values('timestamp_seconds').reset_index(drop=True)
        
        # Create node mappings (IP addresses -> node IDs)
        print("\n4. Creating node mappings...")
        df, node_mapping = self._create_node_mappings(df)
        
        # Ensure strictly increasing timestamps per node
        print("\n5. Validating and fixing timestamp ordering...")
        df = self._fix_timestamp_ordering(df)
        
        # Create edge features
        print("\n6. Creating edge features...")
        edge_features = self._create_edge_features(df)
        
        # Create node features
        print("\n7. Creating node features...")
        node_features = self._create_node_features(df, node_mapping)
        
        # Save to TGN format
        print("\n8. Saving to TGN format...")
        self._save_tgn_format(df, edge_features, node_features)
        
        # Print statistics
        self._print_statistics(df, node_mapping)
        
        return df, edge_features, node_features
    
    def _load_data(self):
        """Load and clean the CSV data"""
        df = pd.read_csv(self.input_csv_path)
        
        # Clean column names (remove spaces)
        df.columns = df.columns.str.strip()
        
        # Remove rows with missing critical data
        df = df.dropna(subset=['Source IP', 'Destination IP', 'Timestamp', 'Label'])
        
        # Basic cleaning
        df = df.replace([np.inf, -np.inf], np.nan)
        df = df.fillna(0)
        
        print(f"   Loaded {len(df)} interactions")
        print(f"   Columns: {list(df.columns)[:10]}...")  # Show first 10 columns
        
        return df
    
    def _parse_timestamps(self, df):
        """Parse timestamps to seconds since epoch"""
        try:
            # Try the format in your CSV
            df['datetime'] = pd.to_datetime(df['Timestamp'], format='%d/%m/%Y %H:%M')
        except:
            try:
                # Try alternative format
                df['datetime'] = pd.to_datetime(df['Timestamp'])
            except:
                raise ValueError("Could not parse timestamps. Check the format.")
        
        # Convert to seconds since epoch
        df['timestamp_seconds'] = df['datetime'].astype('int64') // 10**9
        
        # Add a microsecond offset for interactions at the same second
        df['timestamp_seconds'] = df.groupby('timestamp_seconds').cumcount() * 0.001 + df['timestamp_seconds']
        
        print(f"   Timestamp range: {df['datetime'].min()} to {df['datetime'].max()}")
        print(f"   Unique timestamps: {df['timestamp_seconds'].nunique()}")
        
        return df
    
    def _create_node_mappings(self, df):
        """Create node IDs from IP addresses"""
        # Get all unique IPs
        all_ips = pd.concat([df['Source IP'], df['Destination IP']]).unique()
        
        # Create mapping
        node_mapping = {ip: idx for idx, ip in enumerate(all_ips)}
        
        # Add node IDs to dataframe
        df['source_node_id'] = df['Source IP'].map(node_mapping)
        df['target_node_id'] = df['Destination IP'].map(node_mapping)
        
        print(f"   Total unique nodes: {len(node_mapping)}")
        print(f"   Sample mapping: {list(node_mapping.items())[:5]}")
        
        return df, node_mapping
    
    def _fix_timestamp_ordering(self, df):
        """Ensure timestamps are strictly increasing for each node"""
        # Track last timestamp per node
        node_last_time = {}
        fixed_count = 0
        
        # Create a copy to avoid SettingWithCopyWarning
        df = df.copy()
        
        for idx in range(len(df)):
            src = df.at[idx, 'source_node_id']
            dst = df.at[idx, 'target_node_id']
            ts = df.at[idx, 'timestamp_seconds']
            
            # Check source node
            if src in node_last_time:
                if ts <= node_last_time[src]:
                    # Fix by making timestamp slightly larger
                    df.at[idx, 'timestamp_seconds'] = node_last_time[src] + 0.001
                    ts = df.at[idx, 'timestamp_seconds']
                    fixed_count += 1
            
            node_last_time[src] = df.at[idx, 'timestamp_seconds']
            
            # Check destination node
            if dst in node_last_time and dst != src:
                if ts <= node_last_time[dst]:
                    df.at[idx, 'timestamp_seconds'] = max(ts, node_last_time[dst] + 0.001)
                    fixed_count += 1
            
            node_last_time[dst] = df.at[idx, 'timestamp_seconds']
        
        print(f"   Fixed {fixed_count} timestamp ordering issues")
        
        # Resort after fixing
        df = df.sort_values('timestamp_seconds').reset_index(drop=True)
        
        return df
    
    def _create_edge_features(self, df):
        """Create edge features from flow statistics"""
        # Select numerical features for edges
        feature_columns = [
            'Flow Duration', 'Total Fwd Packets', 'Total Backward Packets',
            'Total Length of Fwd Packets', 'Total Length of Bwd Packets',
            'Fwd Packet Length Max', 'Fwd Packet Length Min', 'Fwd Packet Length Mean',
            'Bwd Packet Length Max', 'Bwd Packet Length Min', 'Bwd Packet Length Mean',
            'Flow Bytes/s', 'Flow Packets/s', 'Flow IAT Mean', 'Flow IAT Std',
            'Fwd IAT Total', 'Fwd IAT Mean', 'Bwd IAT Total', 'Bwd IAT Mean',
            'Fwd Header Length', 'Bwd Header Length', 'Fwd Packets/s', 'Bwd Packets/s',
            'Min Packet Length', 'Max Packet Length', 'Packet Length Mean',
            'FIN Flag Count', 'SYN Flag Count', 'RST Flag Count',
            'ACK Flag Count', 'URG Flag Count', 'Down/Up Ratio',
            'Average Packet Size', 'Avg Fwd Segment Size', 'Avg Bwd Segment Size',
            'Init_Win_bytes_forward', 'Init_Win_bytes_backward'
        ]
        
        # Get available columns
        available_cols = [col for col in feature_columns if col in df.columns]
        print(f"   Using {len(available_cols)} edge features")
        
        # Extract features
        edge_features = df[available_cols].values.astype(np.float32)
        
        # Handle NaN and inf
        edge_features = np.nan_to_num(edge_features, nan=0.0, posinf=0.0, neginf=0.0)
        
        # Normalize
        mean = np.mean(edge_features, axis=0, keepdims=True)
        std = np.std(edge_features, axis=0, keepdims=True)
        std[std == 0] = 1
        edge_features = (edge_features - mean) / std
        
        print(f"   Edge features shape: {edge_features.shape}")
        
        return edge_features
    
    def _create_node_features(self, df, node_mapping):
        """Create node features based on IP statistics"""
        n_nodes = len(node_mapping)
        n_features = 100  # TGN default
        
        if self.randomize_features:
            # Random features for testing
            node_features = np.random.randn(n_nodes, n_features).astype(np.float32)
        else:
            # Create meaningful node features
            node_features = np.zeros((n_nodes, n_features), dtype=np.float32)
            
            # Feature 0-9: Basic statistics
            for node_id in range(n_nodes):
                # Get flows where this node is source or destination
                src_mask = df['source_node_id'] == node_id
                dst_mask = df['target_node_id'] == node_id
                
                node_flows = df[src_mask | dst_mask]
                
                if len(node_flows) > 0:
                    node_features[node_id, 0] = len(node_flows[src_mask])  # Times as source
                    node_features[node_id, 1] = len(node_flows[dst_mask])  # Times as destination
                    node_features[node_id, 2] = node_flows['Flow Duration'].mean()  # Avg duration
                    node_features[node_id, 3] = node_flows['Total Fwd Packets'].mean()  # Avg fwd packets
                    node_features[node_id, 4] = node_flows['Total Backward Packets'].mean()  # Avg bwd packets
                    node_features[node_id, 5] = node_flows['Flow Bytes/s'].mean()  # Avg bytes/s
                    node_features[node_id, 6] = node_flows['Flow Packets/s'].mean()  # Avg packets/s
                    
                    # Attack ratio
                    attacks = node_flows['Label'] != 'BENIGN'
                    node_features[node_id, 7] = attacks.mean() if len(attacks) > 0 else 0
            
            # Fill remaining features with random noise (to match dimension)
            node_features[:, 10:] = np.random.randn(n_nodes, n_features - 10).astype(np.float32) * 0.1
            
            # Normalize
            mean = np.mean(node_features, axis=0, keepdims=True)
            std = np.std(node_features, axis=0, keepdims=True)
            std[std == 0] = 1
            node_features = (node_features - mean) / std
        
        print(f"   Node features shape: {node_features.shape}")
        
        return node_features
    
    def _save_tgn_format(self, df, edge_features, node_features):
        """Save data in TGN format"""
        
        # 1. Save the main interaction data (ml_cicids.csv)
        ml_data = pd.DataFrame({
            'u': df['source_node_id'],
            'i': df['target_node_id'],
            'ts': df['timestamp_seconds'],
            'idx': np.arange(len(df)),
            'label': (df['Label'] != 'BENIGN').astype(int)
        })
        
        ml_path = f'{self.output_dir}/ml_cicids.csv'
        ml_data.to_csv(ml_path, index=False)
        print(f"   Saved interactions to: {ml_path}")
        
        # 2. Save edge features (ml_cicids.npy)
        edge_path = f'{self.output_dir}/ml_cicids.npy'
        np.save(edge_path, edge_features)
        print(f"   Saved edge features to: {edge_path}")
        
        # 3. Save node features (ml_cicids_node.npy)
        node_path = f'{self.output_dir}/ml_cicids_node.npy'
        np.save(node_path, node_features)
        print(f"   Saved node features to: {node_path}")
        
        # 4. Save node mapping for reference
        mapping_path = f'{self.output_dir}/node_mapping.csv'
        mapping_df = pd.DataFrame([
            {'node_id': node_id, 'ip': ip} 
            for ip, node_id in node_mapping.items()
        ])
        mapping_df.to_csv(mapping_path, index=False)
        print(f"   Saved node mapping to: {mapping_path}")
    
    def _print_statistics(self, df, node_mapping):
        """Print dataset statistics"""
        print("\n" + "="*60)
        print("DATASET STATISTICS")
        print("="*60)
        
        # Basic stats
        n_interactions = len(df)
        n_nodes = len(node_mapping)
        
        # Count attacks
        n_attacks = (df['Label'] != 'BENIGN').sum()
        n_benign = n_interactions - n_attacks
        
        # Time range
        time_min = df['timestamp_seconds'].min()
        time_max = df['timestamp_seconds'].max()
        time_span_days = (time_max - time_min) / (24 * 3600)
        
        print(f"\nTotal Interactions: {n_interactions:,}")
        print(f"Total Unique Nodes: {n_nodes:,}")
        print(f"\nClass Distribution:")
        print(f"  - BENIGN: {n_benign:,} ({n_benign/n_interactions*100:.1f}%)")
        print(f"  - ATTACKS: {n_attacks:,} ({n_attacks/n_interactions*100:.1f}%)")
        print(f"\nTime Range:")
        print(f"  - From: {pd.to_datetime(time_min, unit='s')}")
        print(f"  - To: {pd.to_datetime(time_max, unit='s')}")
        print(f"  - Span: {time_span_days:.2f} days")
        
        # Node activity stats
        node_degrees = pd.concat([
            df['source_node_id'].value_counts(),
            df['target_node_id'].value_counts()
        ]).groupby(level=0).sum()
        
        print(f"\nNode Activity:")
        print(f"  - Avg interactions per node: {node_degrees.mean():.1f}")
        print(f"  - Max interactions: {node_degrees.max()}")
        print(f"  - Min interactions: {node_degrees.min()}")
        print("="*60)


# Standalone function to match TGN's expected interface
def get_cicids_data(dataset_name, different_new_nodes_between_val_and_test=False, 
                   randomize_features=False):
    """
    This function matches the interface of the original get_data() function
    """
    
    # For CICIDS, the dataset_name is just an identifier
    # We'll look for the CSV file in ./data/{dataset_name}.csv
    input_path = f'./data/{dataset_name}.csv'
    
    # If the file doesn't exist, try alternative paths
    if not os.path.exists(input_path):
        # Try with .data extension
        alt_path = f'./data/{dataset_name}.data'
        if os.path.exists(alt_path):
            input_path = alt_path
        else:
            # Default to looking for cicids.csv
            input_path = './data/cicids.csv'
    
    # Run preprocessor
    preprocessor = CICIDSTGNPreprocessor(
        input_csv_path=input_path,
        output_dir='/content/data',
        randomize_features=randomize_features
    )
    
    df, edge_features, node_features = preprocessor.preprocess()
    
    # Create Data objects (to match TGN's expected format)
    from types import SimpleNamespace
    
    # This is a simplified version - you'll need to import your actual Data class
    # or define it here
    class Data:
        def __init__(self, sources, destinations, timestamps, edge_idxs, labels):
            self.sources = sources
            self.destinations = destinations
            self.timestamps = timestamps
            self.edge_idxs = edge_idxs
            self.labels = labels
            self.n_interactions = len(sources)
            self.unique_nodes = set(sources) | set(destinations)
            self.n_unique_nodes = len(self.unique_nodes)
    
    # Create full data
    full_data = Data(
        df['source_node_id'].values,
        df['target_node_id'].values,
        df['timestamp_seconds'].values,
        np.arange(len(df)),
        (df['Label'] != 'BENIGN').astype(int).values
    )
    
    # Split by time
    timestamps = df['timestamp_seconds'].values
    val_time, test_time = list(np.quantile(timestamps, [0.70, 0.85]))
    
    train_mask = timestamps <= val_time
    val_mask = np.logical_and(timestamps > val_time, timestamps <= test_time)
    test_mask = timestamps > test_time
    
    # Create splits
    train_data = Data(
        df['source_node_id'][train_mask].values,
        df['target_node_id'][train_mask].values,
        timestamps[train_mask],
        np.arange(len(df))[train_mask],
        (df['Label'] != 'BENIGN').astype(int)[train_mask].values
    )
    
    val_data = Data(
        df['source_node_id'][val_mask].values,
        df['target_node_id'][val_mask].values,
        timestamps[val_mask],
        np.arange(len(df))[val_mask],
        (df['Label'] != 'BENIGN').astype(int)[val_mask].values
    )
    
    test_data = Data(
        df['source_node_id'][test_mask].values,
        df['target_node_id'][test_mask].values,
        timestamps[test_mask],
        np.arange(len(df))[test_mask],
        (df['Label'] != 'BENIGN').astype(int)[test_mask].values
    )
    
    # For new nodes (simplified - just return empty for now)
    new_node_val_data = Data([], [], [], [], [])
    new_node_test_data = Data([], [], [], [], [])
    
    return node_features, edge_features, full_data, train_data, val_data, test_data, \
           new_node_val_data, new_node_test_data


